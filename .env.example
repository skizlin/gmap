# Copy this file to .env and fill in your values.
# .env is gitignored; do not commit real keys.

# BetsAPI (b365api.com) token for event-details API.
# Used when a domain event is created or mapped (fetch markets for Bwin, Bet365, 1xbet).
# Get your token from https://betsapi.com/
BETSAPI_TOKEN=your_betsapi_token_here
