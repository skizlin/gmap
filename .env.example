# Copy this file to .env and fill in your values.
# .env is gitignored; do not commit real keys.

# BetsAPI (b365api.com) token for event-details API.
# Used when a domain event is created or mapped (fetch markets for Bwin, Bet365, 1xbet).
# Get your token from https://betsapi.com/
BETSAPI_TOKEN=your_betsapi_token_here

# Server only: automatic feed pulls (one full feed per UTC hour, rotating). Uses BETSAPI_TOKEN.
# Leave unset locally; set SCHEDULED_FEED_PULL=1 on the server. Requires single uvicorn worker.
# SCHEDULED_FEED_PULL=1
# SCHEDULED_FEED_PULL_FEEDS=bet365,betfair,1xbet,bwin
# SCHEDULED_FEED_PULL_CONCURRENCY=5
# SCHEDULED_FEED_PULL_START_DELAY_SEC=60

# RBAC (optional): trust X-RBAC-Actor-User-Id on JSON APIs so that user (if is_superadmin in users.csv)
# bypasses Master-role permission caps and can change SuperAdmin flags. Off by default; use only in trusted setups.
# RBAC_TRUST_ACTOR_HEADER=1

# Sign-in (dev/session): when GMP_DEV_LOGIN=1, every page and API requires a session from /dev/login.
# Admin “Online” uses last request time (in memory; cleared on restart). Default idle window 180 seconds.
# RBAC_ONLINE_IDLE_SECONDS=180
# GMP_DEV_LOGIN=1
# GMP_DEV_SESSION_SECRET=use_a_long_random_string_here_at_least_32_chars
# PIN for users with is_superadmin in CSV — set only on your machine, never commit a real value:
# GMP_SUPERADMIN_PIN=
# Default PIN for normal users if login_pin is empty in users.csv:
# GMP_DEFAULT_USER_PIN=1234
