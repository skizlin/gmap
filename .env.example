# Copy this file to .env and fill in your values.
# .env is gitignored; do not commit real keys.

# BetsAPI (b365api.com) token for event-details API.
# Used when a domain event is created or mapped (fetch markets for Bwin, Bet365, 1xbet).
# Get your token from https://betsapi.com/
BETSAPI_TOKEN=your_betsapi_token_here

# Server only: automatic feed pulls (one full feed per UTC hour, rotating). Uses BETSAPI_TOKEN.
# Leave unset locally; set SCHEDULED_FEED_PULL=1 on the server. Requires single uvicorn worker.
# SCHEDULED_FEED_PULL=1
# SCHEDULED_FEED_PULL_FEEDS=bet365,betfair,1xbet,bwin
# SCHEDULED_FEED_PULL_CONCURRENCY=5
# SCHEDULED_FEED_PULL_START_DELAY_SEC=60
